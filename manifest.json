{
  "manifest_version": 3,
  "name": "FocusLens",
  "version": "0.1.0",
  "description": "Cognitive fatigue-aware interface adapter",

  "permissions": ["activeTab", "storage", "scripting", "tabs", "camera"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "worker.bundle.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.bundle.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "FocusLens"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "assets/mediapipe/*",
        "eyetracking.bundle.js",
        "eyetracking.html"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
